<Window x:Class="Jot.Controls.PillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:Jot.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable, Segoe UI"
        AutomationProperties.Name="Jot status">
    <!-- Dark translucent capsule reads over any app, in either OS theme (the overlay convention). -->
    <Border x:Name="Capsule" CornerRadius="18" Background="#F01B1B1F" Padding="16,9"
            MinWidth="150" Cursor="SizeAll">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <Grid x:Name="LineRow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- recording dot -->
                    <ColumnDefinition Width="Auto" />  <!-- waveform -->
                    <ColumnDefinition Width="*" />      <!-- live caption / status line (absorbs the slack so the pill width is stable) -->
                    <ColumnDefinition Width="Auto" />  <!-- elapsed timer -->
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="Dot" Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center"
                         Fill="{DynamicResource JotRecordingBrush}" />
                <ctl:WaveformView x:Name="Wave" Grid.Column="1" Width="150" Height="22"
                                  Margin="12,0,10,0" VerticalAlignment="Center" />
                <TextBlock x:Name="LineText" Grid.Column="2" VerticalAlignment="Center"
                           HorizontalAlignment="Stretch" TextAlignment="Right" Margin="6,0,0,0"
                           Foreground="White" FontSize="13" MaxWidth="320"
                           TextTrimming="None" Visibility="Collapsed" />
                <TextBlock x:Name="Elapsed" Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="#B0FFFFFF" FontSize="12"
                           FontFamily="{DynamicResource JotMonoFont}" />
            </Grid>

            <!-- Key hint shown while recording (e.g. "Alt + Space to stop   ·   Esc to cancel"), so the
                 user always knows how to stop or discard without hunting for the shortcut. -->
            <TextBlock x:Name="Hint" Visibility="Collapsed" Margin="21,5,0,0"
                       Foreground="#8CFFFFFF" FontSize="11" />

            <!-- Expanded content (multi-line transcript + actions), revealed on click. -->
            <StackPanel x:Name="ExpandPanel" Visibility="Collapsed" Margin="0,10,0,2" MaxWidth="420">
                <ScrollViewer x:Name="TranscriptScroll" MaxHeight="140"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="TranscriptText" Foreground="#E8FFFFFF" FontSize="13"
                               TextWrapping="Wrap" />
                </ScrollViewer>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button x:Name="CopyButton" Content="Copy" Padding="12,3" Click="OnCopyClick" />
                    <Button x:Name="StopButton" Content="Stop" Padding="12,3" Margin="8,0,0,0"
                            Click="OnStopClick" Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
