<UserControl x:Class="Jot.Controls.HotkeyBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True" IsTabStop="True" MinWidth="150">
    <Border x:Name="Root" Padding="10,4" CornerRadius="4"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            Cursor="Hand">
        <TextBlock x:Name="Label" FontFamily="{StaticResource JotMonoFont}" FontSize="12"
                   TextAlignment="Center" HorizontalAlignment="Center" />
    </Border>
</UserControl>
