<ui:FluentWindow x:Class="Jot.Controls.DonationsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Donate to charity"
                 Width="560" Height="660" MinWidth="460" MinHeight="420"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Donate to charity" />

        <StackPanel Grid.Row="1" Margin="20,10,20,6">
            <TextBlock x:Name="TimeSavedText" Style="{DynamicResource SubtitleTextBlockStyle}" FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="If it's helped, consider passing some of that forward — to people who don't have basic necessities." />
            <!-- The "100% via Every.org" pledge and the running total share one line and the body font,
                 so the header reads as two type styles (headline + body), not four. -->
            <TextBlock x:Name="CharityLine" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="100% of donations go to charity via Every.org." />
            <ui:TextBox x:Name="SearchBox" Margin="0,12,0,0" PlaceholderText="Search charities"
                        Icon="{ui:SymbolIcon Search24}" TextChanged="OnSearchChanged" Visibility="Collapsed" />
        </StackPanel>

        <ScrollViewer Grid.Row="2" Margin="10,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:ProgressRing x:Name="Spinner" IsIndeterminate="True" Margin="0,48"
                                 HorizontalAlignment="Center" />
                <TextBlock x:Name="ErrorText" Visibility="Collapsed" Margin="24" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ItemsControl x:Name="CharityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Charity logo from the summary's logo_url, with a heart fallback behind it
                                         (shows through when the URL is missing or fails to load). -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" Margin="0,0,12,0"
                                            VerticalAlignment="Center" ClipToBounds="True"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                        <Grid>
                                            <ui:SymbolIcon Symbol="Heart24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <Image Source="{Binding LogoUrl}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding AmountDisplay}" FontSize="12" Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                   Visibility="{Binding HasAmount, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <!-- One-tap preset amounts open every.org's pre-filled donate page
                                         (www.every.org/<slug>/donate?amount=N), matching the Mac. -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button Content="$2" Appearance="Primary" MinWidth="44" Margin="0,0,6,0"
                                                   Tag="2" Click="OnDonateAmount" ToolTip="Donate $2 via Every.org" />
                                        <ui:Button Content="$10" Appearance="Primary" MinWidth="44"
                                                   Tag="10" Click="OnDonateAmount" ToolTip="Donate $10 via Every.org" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10">
            <ui:Button Content="Browse all on the web" Icon="{ui:SymbolIcon Globe24}"
                       Click="OnBrowseAll" Margin="0,0,8,0" />
            <ui:Button Content="Close" Click="OnClose" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
