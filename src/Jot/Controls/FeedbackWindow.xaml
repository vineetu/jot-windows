<ui:FluentWindow x:Class="Jot.Controls.FeedbackWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Send feedback"
                 Width="500" Height="420" MinWidth="380" MinHeight="320"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Send feedback" />

        <TextBlock Grid.Row="1" Margin="20,10,20,6" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Tell us what's working or what's broken. This goes straight to the developer — no email client, no account." />

        <ui:TextBox Grid.Row="2" x:Name="FeedbackBox" Margin="20,6,20,6"
                    AcceptsReturn="True" TextWrapping="Wrap"
                    VerticalContentAlignment="Top"
                    VerticalScrollBarVisibility="Auto"
                    PlaceholderText="Your feedback…" />

        <TextBlock Grid.Row="3" x:Name="StatusText" Margin="20,0,20,4" TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16">
            <ui:Button x:Name="SendButton" Content="Send" Appearance="Primary" Margin="0,0,8,0"
                       Click="OnSend" />
            <ui:Button x:Name="CloseButton" Content="Close" Click="OnClose" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
