<Page x:Class="Jot.Views.AskJotPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Ask Jot">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Ask Jot" Style="{DynamicResource TitleTextBlockStyle}" />
                <TextBlock Text="On-device help, grounded in Jot's docs."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Appearance="Secondary"
                       Content="New chat" Icon="{ui:SymbolIcon Add24}" Command="{Binding NewChatCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="ChatSparkle24" FontSize="36" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Ask about any Jot feature" Style="{DynamicResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" Margin="0,10,0,12" />
                    <ItemsControl ItemsSource="{Binding Starters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                           Margin="0,0,0,8" Content="{Binding}"
                                           Command="{Binding DataContext.UseStarterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Messages}"
                              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,10" MaxWidth="560">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" PlaceholderText="Ask a question…"
                        Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SendCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>
            <ui:Button Grid.Column="1" Margin="8,0,0,0" Appearance="Primary"
                       Icon="{ui:SymbolIcon Send24}" Command="{Binding SendCommand}" />
        </Grid>
    </Grid>
</Page>
