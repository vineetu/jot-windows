<Page x:Class="Jot.Views.ShortcutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:ctl="clr-namespace:Jot.Controls"
      Title="Shortcuts">
    <Page.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}">
            <Setter Property="Margin" Value="2,22,0,8" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="820">
            <TextBlock Text="Shortcuts" Style="{DynamicResource TitleTextBlockStyle}" Margin="0,0,0,4" />

            <!-- Rebinding re-enabled: HotkeyBox click-to-capture is verified working (capture updates the
                 bound chord; the VM persists it and App re-registers). The chords bind TwoWay to the
                 shared SettingsViewModel. Physical-keyboard round-trip still wants a hands-on test — see
                 docs/plans/fixit-worklist.md (A5). -->
            <ui:InfoBar IsOpen="True" Severity="Informational" IsClosable="False" Margin="0,12,0,4"
                        Title="Change a shortcut"
                        Message="Click a shortcut, then press the new key combination. Backspace clears it; Esc cancels." />

            <ctl:SettingRow Title="Toggle recording" Description="Start and stop dictation.">
                <ctl:HotkeyBox Chord="{Binding ToggleRecordingHotkey, Mode=TwoWay}" />
            </ctl:SettingRow>
            <ctl:SettingRow Title="Stop &amp; save recording"
                            Description="Ends the current recording and saves it (active only while recording). Never discards.">
                <ctl:HotkeyBox Chord="{Binding CancelRecordingHotkey, Mode=TwoWay}" />
            </ctl:SettingRow>

            <Border Height="24" />
        </StackPanel>
    </ScrollViewer>
</Page>
