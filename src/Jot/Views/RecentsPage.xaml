<Page x:Class="Jot.Views.RecentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:Jot.Models"
      Title="Recents">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title + record button + drop zone -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Width="60" Height="60" CornerRadius="30" Appearance="Primary"
                           Command="{Binding StartDictationCommand}"
                           ToolTip="Start dictation"
                           AutomationProperties.Name="Start dictation">
                    <ui:SymbolIcon Symbol="Mic24" FontSize="24" />
                </ui:Button>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Recents" Style="{DynamicResource TitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Press" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Border Margin="6,0" Padding="6,1" CornerRadius="4"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                            <TextBlock Text="{Binding HotkeyLabel}" FontFamily="{StaticResource JotMonoFont}" FontSize="12" />
                        </Border>
                        <TextBlock Text="anywhere, speak, and it's pasted at your cursor."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" x:Name="DropZone" Margin="24,0,0,0" MinHeight="60"
                    CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="1.4" AllowDrop="True"
                    DragEnter="OnDropZoneDragEnter" DragLeave="OnDropZoneDragLeave" Drop="OnDropZoneDrop">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource ControlStrokeColorDefault}" Opacity="0.9" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="ArrowUpload24" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        Drop an audio or video file, or
                        <Hyperlink Click="OnBrowseClick">browse</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Search -->
        <ui:TextBox Grid.Row="1" x:Name="SearchBox" Margin="0,0,0,10"
                    PlaceholderText="Search transcripts, titles, and tags"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Icon="{ui:SymbolIcon Search24}" />

        <!-- Tag filter chips -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Tags}" Margin="0,0,0,12"
                      Visibility="{Binding Tags.Count, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Button Margin="0,0,8,0" Padding="12,4" Content="{Binding}"
                               Command="{Binding DataContext.ToggleTagCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                               CommandParameter="{Binding}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Library list -->
        <Grid Grid.Row="3">
            <ListView x:Name="List" ItemsSource="{Binding Items}"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      VirtualizingPanel.ScrollUnit="Item"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="2,10,0,6"
                                           Style="{DynamicResource CaptionTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:RecordingItem}">
                        <ui:CardAction Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                       CommandParameter="{Binding}" Padding="14,12" IsChevronVisible="False">
                            <ui:CardAction.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy transcript"
                                              Command="{Binding DataContext.CopyCommand, Source={x:Reference List}}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="Delete"
                                              Command="{Binding DataContext.DeleteCommand, Source={x:Reference List}}"
                                              CommandParameter="{Binding}" />
                                </ContextMenu>
                            </ui:CardAction.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,12,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Top">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Mic24" FontSize="16"
                                                       Visibility="{Binding IsDictationRow, Converter={StaticResource BoolToVis}}" />
                                        <ui:SymbolIcon Symbol="Wand24" FontSize="16"
                                                       Visibility="{Binding IsRewriteRow, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4" VerticalAlignment="Center"
                                                Background="{DynamicResource JotWarningBrush}"
                                                Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Needs transcription" FontSize="11" Foreground="#1B1B1F" />
                                        </Border>
                                        <TextBlock Text="· edited" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding IsEdited, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Transcript}" Margin="0,3,0,0" MaxHeight="38"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding TimeText}" HorizontalAlignment="Right" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding DurationText}" HorizontalAlignment="Right" Margin="0,2,0,0"
                                               FontSize="12" FontFamily="{StaticResource JotMonoFont}"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Visibility="{Binding IsDictationRow, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty states -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <ui:SymbolIcon Symbol="Mic24" FontSize="36" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Nothing here yet" Style="{DynamicResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" Margin="0,10,0,4" />
                <TextBlock Text="Press your hotkey and start speaking — your dictations will show up here."
                           TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock Text="No recordings match your search."
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Visibility="{Binding HasNoMatches, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</Page>
