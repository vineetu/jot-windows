<Page x:Class="Jot.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="About">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="760">
            <TextBlock Text="About" Style="{DynamicResource TitleTextBlockStyle}" Margin="0,0,0,16" />

            <!-- Identity -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="64" Height="64" CornerRadius="16"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                    <ui:SymbolIcon Symbol="Mic24" FontSize="30" Foreground="White" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Jot for Windows" Style="{DynamicResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Free, on-device dictation. Press a key, speak, and it's pasted at your cursor."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="Version 0.1.0 (preview)" Margin="0,2,0,0" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- HIDDEN until real: no network check yet (hardcoded "up to date"). Restore when
                 Velopack auto-update lands. See docs/plans/fixit-worklist.md (B3). -->
            <ui:Button Content="Check for updates" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnCheckUpdates"
                       Visibility="Collapsed" />

            <!-- Privacy pledge -->
            <ui:Card Margin="0,20,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24" Foreground="{DynamicResource JotSuccessBrush}" />
                        <TextBlock Text="Your privacy" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Transcription runs entirely on your PC — audio and transcripts never leave the device. No accounts, no telemetry. Optional AI cleanup only calls a provider you configure yourself." />
                </StackPanel>
            </ui:Card>

            <!-- Usage impact (on-device counters — D2) -->
            <ui:Card Margin="0,16,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Timer24" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Your impact" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="StatsText" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </ui:Card>

            <!-- Support -->
            <TextBlock Text="Support Jot" Style="{DynamicResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />
            <ui:Button Content="Donate to charity" Icon="{ui:SymbolIcon Heart24}" Appearance="Primary" Click="OnDonate" />

            <!-- Troubleshooting -->
            <TextBlock Text="Troubleshooting" Style="{DynamicResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="View log" Icon="{ui:SymbolIcon DocumentText24}" Margin="0,0,8,0" Click="OnViewLog" />
                <ui:Button Content="Restart Jot" Icon="{ui:SymbolIcon ArrowClockwise24}" Margin="0,0,8,0" Click="OnRestart" />
                <ui:Button Content="Send feedback" Icon="{ui:SymbolIcon Mail24}" Click="OnSendFeedback" />
            </StackPanel>

            <Border Height="24" />
        </StackPanel>
    </ScrollViewer>
</Page>
