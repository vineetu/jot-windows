<ui:FluentWindow x:Class="Jot.Views.SetupWizardWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Set up Jot"
                 Icon="pack://application:,,,/Assets/jot.ico"
                 Width="600" Height="600" ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica" WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False" Title="Set up Jot" />

        <StackPanel Grid.Row="1" Margin="40,8,40,0">
            <TextBlock Text="{Binding StepTitle}" Style="{DynamicResource TitleTextBlockStyle}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding StepSubtitle}" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="40,24,40,0">
            <!-- 0 Welcome -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=0}">
                <Ellipse Width="96" Height="96" HorizontalAlignment="Center">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/jot-logo.png" Stretch="UniformToFill" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="Nothing you say leaves your PC." Margin="0,20,0,0" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 1 Permissions -->
            <StackPanel VerticalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=1}">
                <ui:Button Content="Open microphone privacy settings" Icon="{ui:SymbolIcon Open24}"
                           Command="{Binding OpenMicPrivacyCommand}" HorizontalAlignment="Left" />
                <TextBlock Margin="0,14,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="If Jot isn't listed, make sure &quot;Let apps access your microphone&quot; is on. Unlike macOS, Windows doesn't require separate input-monitoring or accessibility permissions." />
            </StackPanel>

            <!-- 2 Language -->
            <StackPanel VerticalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=2}">
                <ComboBox Width="220" HorizontalAlignment="Left" ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding Language, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource JotSuccessBrush}" />
                    <TextBlock Text="On-device model ready (≈600 MB)" Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- 3 Microphone -->
            <StackPanel VerticalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=3}">
                <ComboBox Width="280" HorizontalAlignment="Left" DisplayMemberPath="Name"
                          ItemsSource="{Binding InputDevices}" SelectedItem="{Binding SelectedDevice, Mode=TwoWay}" />
                <TextBlock Text="Input level" Margin="0,20,0,6"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ProgressBar x:Name="MeterBar" Minimum="0" Maximum="1" Value="0" Height="8" Width="360"
                             HorizontalAlignment="Left" />
            </StackPanel>

            <!-- 4 Shortcut -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=4}">
                <Border Padding="24,14" CornerRadius="10" HorizontalAlignment="Center"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <TextBlock Text="{Binding HotkeyLabel}" FontFamily="{StaticResource JotMonoFont}" FontSize="22" />
                </Border>
                <TextBlock Text="Press it anywhere to start, and again to stop." Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 5 Save location -->
            <StackPanel VerticalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=5}">
                <TextBlock Text="Save location" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                <Border Padding="12,8" CornerRadius="6" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <TextBlock Text="{Binding DataDirectory}" TextTrimming="CharacterEllipsis"
                               FontFamily="{StaticResource JotMonoFont}" FontSize="13" />
                </Border>
                <ui:Button Content="Change…" Margin="0,12,0,0" HorizontalAlignment="Left"
                           Icon="{ui:SymbolIcon Open24}" Command="{Binding BrowseSaveLocationCommand}" />
            </StackPanel>

            <!-- 6 Done -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding StepIndex, Converter={StaticResource IndexToVis}, ConverterParameter=6}">
                <ui:SymbolIcon Symbol="CheckmarkCircle48" FontSize="72"
                               Foreground="{DynamicResource JotSuccessBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="40,20,40,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Content="Back" Appearance="Secondary" Command="{Binding BackCommand}"
                       Visibility="{Binding IsFirstStep, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

            <StackPanel Grid.Column="1" x:Name="Dots" Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button Content="Skip" Appearance="Transparent" Margin="0,0,8,0" Command="{Binding SkipCommand}"
                           Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                <ui:Button Content="Next" Appearance="Primary" Command="{Binding NextCommand}"
                           Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                <ui:Button Content="Get started" Appearance="Primary" Command="{Binding NextCommand}"
                           Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
